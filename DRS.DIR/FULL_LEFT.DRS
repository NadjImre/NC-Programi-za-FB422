G90 G18 DIAM90
X0 Z=-ds_tool_width-ds_podhodZ
if ((ds_taper_length1>0) and (ds_taper_angle1<>0))
   X0 Z=-ds_taper_length1
   X=-ds_taper_length1*tan(ds_taper_angle1) Z0 Rnd=ds_radius1
else
   X0 Z0 Rnd=ds_radius1
endif
if (ds_margin1>0)
   Z0 X=IC(-2*ds_Margin1)
endif
Z=-ds_Face_Length1*tan(ds_Face_Angle1) X=-2*ds_Face_Length1 RND=ds_PodhodZ/2
Z=ds_PodhodZ
M17
