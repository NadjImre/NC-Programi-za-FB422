X0 Z=ds_wheel_width+ds_podhodZ
if ((ds_taper_length2>0) and (ds_taper_angle2<>0))
   X0 Z=ds_taper_length2
   X=-ds_taper_length2*tan(ds_taper_angle2) Z0 Rnd=ds_radius2
else
   X0 Z0 Rnd=ds_radius2
endif
if (ds_margin2>0)
   Z0 X=IC(-2*ds_Margin2)
endif
Z=ds_Face_Depth2 X=-2*Face_Depth2*tan(ds_Face_Angle2) 
X=-2*ds_Face_Length2 RND=ds_PodhodX
Z=-ds_PodhodZ
M17
